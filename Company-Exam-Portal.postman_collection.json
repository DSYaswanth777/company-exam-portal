{
  "info": {
    "name": "Company Exam Portal API",
    "description": "Complete API collection for the Company Exam Portal backend.\n\n## Setup\n1. Set the `baseUrl` variable to your server (default: `http://localhost:8000`).\n2. Run **Admin Login** → the `adminToken` variable is auto-saved.\n3. Run **Company Login** → the `companyToken` variable is auto-saved.\n4. Student requests use the `studentToken` variable — set it after calling **Student Login**.\n\n## Auth Header convention\n- Admin endpoints → `Authorization: Bearer {{adminToken}}`\n- Company endpoints → `Authorization: Bearer {{companyToken}}`\n- Student endpoints → `X-Student-Token: {{studentToken}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:8000", "type": "string" },
    { "key": "adminToken",   "value": "",                      "type": "string" },
    { "key": "companyToken", "value": "",                      "type": "string" },
    { "key": "studentToken", "value": "",                      "type": "string" },
    { "key": "companyId",    "value": "1",                     "type": "string" },
    { "key": "driveId",      "value": "1",                     "type": "string" },
    { "key": "questionId",   "value": "1",                     "type": "string" },
    { "key": "collegeId",    "value": "1",                     "type": "string" },
    { "key": "groupId",      "value": "1",                     "type": "string" },
    { "key": "ticketId",     "value": "1",                     "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('adminToken', json.access_token);",
                  "    console.log('Admin token saved:', json.access_token.slice(0,30) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/admin/login", "host": ["{{baseUrl}}"], "path": ["api","auth","admin","login"] }
          },
          "response": []
        },
        {
          "name": "Company Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "company_name", "value": "Acme Corp",        "type": "text" },
                { "key": "username",     "value": "acmecorp",         "type": "text" },
                { "key": "email",        "value": "hr@acme.com",      "type": "text" },
                { "key": "password",     "value": "acme@secure123",   "type": "text" },
                { "key": "logo",         "type": "file",  "src": "/path/to/logo.png", "description": "PNG or JPEG ≤ 2 MB" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/auth/company/register", "host": ["{{baseUrl}}"], "path": ["api","auth","company","register"] }
          },
          "response": []
        },
        {
          "name": "Company Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('companyToken', json.access_token);",
                  "    console.log('Company token saved:', json.access_token.slice(0,30) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"acmecorp\",\n  \"password\": \"acme@secure123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/company/login", "host": ["{{baseUrl}}"], "path": ["api","auth","company","login"] }
          },
          "response": []
        }
      ]
    },
    {
      "name": "👑 Admin — Companies",
      "item": [
        {
          "name": "Get All Companies",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/companies?skip=0&limit=100&status_filter=all",
              "host": ["{{baseUrl}}"], "path": ["api","admin","companies"],
              "query": [
                { "key": "skip",          "value": "0"   },
                { "key": "limit",         "value": "100" },
                { "key": "status_filter", "value": "all", "description": "all | approved | suspended" }
