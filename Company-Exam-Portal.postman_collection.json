            "url": { "raw": "{{baseUrl}}/api/admin/companies/{{companyId}}/notify", "host": ["{{baseUrl}}"], "path": ["api","admin","companies","{{companyId}}","notify"] }
          },
          "response": []
        },
        {
          "name": "Delete Company",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/companies/{{companyId}}", "host": ["{{baseUrl}}"], "path": ["api","admin","companies","{{companyId}}"] }
          },
          "response": []
