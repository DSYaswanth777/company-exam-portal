            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Violation of terms of service\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/admin/companies/{{companyId}}/suspend", "host": ["{{baseUrl}}"], "path": ["api","admin","companies","{{companyId}}","suspend"] }
          },
          "response": []
        },
